{
  "name": "tsundoku-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "storybook": "STORYBOOK=1 storybook dev -p 6006 --no-open",
    "build-storybook": "STORYBOOK=1 storybook build",
    "gen:api": "bunx openapi-typescript ../backend/internal/api/openapi.yaml -o app/utils/api/schema.d.ts",
    "check:api-drift": "bun run gen:api && git diff --exit-code app/utils/api/",
    "build:app": "bash scripts/build-into-backend.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.3",
    "@nuxtjs/color-mode": "^4.0.0",
    "nuxt": "^4.4.6",
    "openapi-fetch": "^0.13.5",
    "reka-ui": "^2.9.9",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/storybook": "^9.0.1",
    "@vue/test-utils": "^2.4.11",
    "eslint": "10.4.1",
    "happy-dom": "^20.10.6",
    "openapi-typescript": "^7.8.0",
    "storybook": "~9.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.3"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "unrs-resolver"
  ],
  "overrides": {
    "typescript-eslint": "8.60.1",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@typescript-eslint/utils": "8.60.1",
    "@typescript-eslint/scope-manager": "8.60.1",
    "@typescript-eslint/typescript-estree": "8.60.1"
  }
}
